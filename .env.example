# ╔══════════════════════════════════════════╗
# ║     SOLANA SNIPER BOT - CONFIG           ║
# ╚══════════════════════════════════════════╝

# Your Solana RPC endpoint (use Helius/QuickNode for speed)
# Free: https://rpc.helius.xyz/?api-key=YOUR_KEY
RPC_URL=https://api.mainnet-beta.solana.com

# Your wallet private key in base58 format
# NEVER share this with anyone
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ── TRADING SETTINGS ──────────────────────

# SOL amount to spend per trade
BUY_AMOUNT_SOL=0.01

# Take profit at +50%
TAKE_PROFIT_PERCENT=50

# Stop loss at -20% (protects capital)
STOP_LOSS_PERCENT=20

# Slippage tolerance in basis points (300 = 3%)
SLIPPAGE_BPS=300

# Max simultaneous open positions
MAX_OPEN_POSITIONS=3

# How often to scan for new pools (milliseconds)
POLL_INTERVAL_MS=3000

# Minimum pool liquidity to consider (in SOL)
MIN_LIQUIDITY_SOL=5
